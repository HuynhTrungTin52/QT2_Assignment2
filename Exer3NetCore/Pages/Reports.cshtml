@page
@model Exer3NetCore.Pages.ReportsModel
@{
    ViewData["Title"] = "Reports";
}

<h1>Reports</h1>

<h4>Best Items (Top Revenue)</h4>
<form method="get" class="row g-3 mb-3">
    <input type="hidden" name="section" value="best" />
    <div class="col-md-2">
        <label class="form-label">Start Date</label>
        <input asp-for="BestFilter.StartDate" class="form-control" type="date" />
    </div>
    <div class="col-md-2">
        <label class="form-label">End Date</label>
        <input asp-for="BestFilter.EndDate" class="form-control" type="date" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Min Quantity</label>
        <input asp-for="BestFilter.MinQuantity" class="form-control" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Size</label>
        <input asp-for="BestFilter.Size" class="form-control" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Agent</label>
        <select asp-for="BestFilter.AgentId" asp-items="Model.AgentOptions" class="form-select">
            <option value="">All</option>
        </select>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary">Filter</button>
    </div>
</form>

<table class="table table-sm table-striped mb-5">
    <thead>
        <tr>
            <th>Item</th>
            <th>Size</th>
            <th class="text-end">Revenue</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.BestItems)
    {
        <tr>
            <td>@item.ItemName</td>
            <td>@item.Size</td>
            <td class="text-end">@item.Revenue.ToString("N0")</td>
        </tr>
    }
    </tbody>
</table>

<h4>Items Purchased by Customer</h4>
<form method="get" class="row g-3 mb-3">
    <input type="hidden" name="section" value="customerItems" />
    <div class="col-md-3">
        <label class="form-label">Customer (AgentID)</label>
        <input asp-for="CustomerItemsFilter.Customer" class="form-control" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Start Date</label>
        <input asp-for="CustomerItemsFilter.StartDate" class="form-control" type="date" />
    </div>
    <div class="col-md-2">
        <label class="form-label">End Date</label>
        <input asp-for="CustomerItemsFilter.EndDate" class="form-control" type="date" />
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary">Filter</button>
    </div>
</form>

<table class="table table-sm table-striped mb-5">
    <thead>
        <tr>
            <th>Customer</th>
            <th>Item</th>
            <th>Size</th>
            <th class="text-end">Quantity</th>
            <th class="text-end">Total</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.CustomerItems)
    {
        <tr>
            <td>@item.Customer</td>
            <td>@item.ItemName</td>
            <td>@item.Size</td>
            <td class="text-end">@item.Quantity</td>
            <td class="text-end">@item.Total.ToString("N0")</td>
        </tr>
    }
    </tbody>
</table>

<h4>Customer Purchases Items</h4>
<form method="get" class="row g-3 mb-3">
    <input type="hidden" name="section" value="customerPurchases" />
    <div class="col-md-2">
        <label class="form-label">Start Date</label>
        <input asp-for="CustomerPurchasesFilter.StartDate" class="form-control" type="date" />
    </div>
    <div class="col-md-2">
        <label class="form-label">End Date</label>
        <input asp-for="CustomerPurchasesFilter.EndDate" class="form-control" type="date" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Size</label>
        <input asp-for="CustomerPurchasesFilter.Size" class="form-control" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Agent</label>
        <select asp-for="CustomerPurchasesFilter.AgentId" asp-items="Model.AgentOptions" class="form-select">
            <option value="">All</option>
        </select>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary">Filter</button>
    </div>
</form>

<table class="table table-sm table-striped">
    <thead>
        <tr>
            <th>Customer</th>
            <th>Item</th>
            <th>Size</th>
            <th class="text-end">Quantity</th>
            <th class="text-end">Total</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.CustomerPurchases)
    {
        <tr>
            <td>@item.Customer</td>
            <td>@item.ItemName</td>
            <td>@item.Size</td>
            <td class="text-end">@item.Quantity</td>
            <td class="text-end">@item.Total.ToString("N0")</td>
        </tr>
    }
    </tbody>
</table>

<h4 class="mt-5">Orders</h4>
<table class="table table-sm table-striped">
    <thead>
        <tr>
            <th>Order</th>
            <th>Date</th>
            <th>Agent</th>
            <th class="text-end">Total</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var order in Model.OrderSummaries)
    {
        <tr>
            <td>@order.OrderId</td>
            <td>@order.OrderDate.ToString("yyyy-MM-dd")</td>
            <td>@order.AgentId</td>
            <td class="text-end">@order.TotalAmount.ToString("N0")</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-primary" asp-page="/OrderReport" asp-route-orderId="@order.OrderId">View</a>
                <a class="btn btn-sm btn-outline-secondary ms-2" asp-page="/OrderReport" asp-page-handler="Export" asp-route-orderId="@order.OrderId">Print PDF</a>
            </td>
        </tr>
    }
    </tbody>
</table>
