@page
@model Exer3NetCore.Pages.OrdersModel
@{
    ViewData["Title"] = "Orders";
}

<h1>Orders</h1>

<form method="post" class="mb-4">
    <div class="row g-3">
        <div class="col-md-3">
        <label asp-for="OrderForm.OrderId" class="form-label"></label>
        <input asp-for="OrderForm.OrderId" class="form-control" />
        <span asp-validation-for="OrderForm.OrderId" class="text-danger"></span>
        </div>
        <div class="col-md-3">
        <label asp-for="OrderForm.OrderDate" class="form-label"></label>
        <input asp-for="OrderForm.OrderDate" class="form-control" type="date" />
        <span asp-validation-for="OrderForm.OrderDate" class="text-danger"></span>
        </div>
        <div class="col-md-3">
        <label asp-for="OrderForm.AgentId" class="form-label"></label>
        <select asp-for="OrderForm.AgentId" asp-items="Model.AgentOptions" class="form-select"></select>
        <span asp-validation-for="OrderForm.AgentId" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="OrderForm.DetailCount" class="form-label"></label>
            <input asp-for="OrderForm.DetailCount" class="form-control" min="1" type="number" />
            <span asp-validation-for="OrderForm.DetailCount" class="text-danger"></span>
        </div>
    </div>

    <h4 class="mt-4">Order Details</h4>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th style="width:30%">Item</th>
                <th style="width:20%">Quantity</th>
                <th style="width:20%">Unit Amount</th>
            </tr>
        </thead>
        <tbody>
        @for (var i = 0; i < Model.DetailInputs.Count; i++)
        {
            <tr>
                <td>
                    <select asp-for="DetailInputs[i].ItemId" asp-items="Model.ItemOptions" class="form-select"></select>
                    <span asp-validation-for="DetailInputs[i].ItemId" class="text-danger"></span>
                </td>
                <td>
                    <input asp-for="DetailInputs[i].Quantity" class="form-control" />
                    <span asp-validation-for="DetailInputs[i].Quantity" class="text-danger"></span>
                </td>
                <td>
                    <input asp-for="DetailInputs[i].UnitAmount" class="form-control" />
                    <span asp-validation-for="DetailInputs[i].UnitAmount" class="text-danger"></span>
                </td>
            </tr>
        }
        </tbody>
    </table>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save Order</button>
        @if (!string.IsNullOrWhiteSpace(Model.CreatedOrderId))
        {
            <a class="btn btn-outline-secondary ms-2" asp-page="/OrderReport" asp-route-orderId="@Model.CreatedOrderId">Print / Export</a>
        }
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
