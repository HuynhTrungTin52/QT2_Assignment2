@model Exer4MVCNetCore.Models.Order

@{
    ViewData["Title"] = "Order Details";
    var details = ViewBag.Details as List<Exer4MVCNetCore.Models.OrderDetail> ?? new List<Exer4MVCNetCore.Models.OrderDetail>();
    var isPrint = ViewBag.IsPrint as bool? ?? false;
}

<!DOCTYPE html>
<html>
<head>
    <title>Order #@Model.OrderId</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css">
    <style type="text/css">
        @@media print {
            .btn, .no-print { display: none; }
        }
    </style>
</head>
<body>
    <div class="container mt-4">
        <div class="row no-print mb-3">
            <div class="col-12">
                <a href="@Url.Action("Index")" class="btn btn-secondary">Back to Orders</a>
                <button onclick="window.print()" class="btn btn-primary">Print</button>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8">
                <h2>Order #@Model.OrderId</h2>
                <hr />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <p><strong>Order Date:</strong> @Model.OrderDate.ToString("yyyy-MM-dd HH:mm")</p>
                        <p><strong>Agent ID:</strong> @Model.AgentId</p>
                    </div>
                </div>

                <h4>Order Details</h4>
                <div class="table-responsive">
                    <table class="table table-bordered">
                        <thead class="table-dark">
                            <tr>
                                <th>Item ID</th>
                                <th>Item Name</th>
                                <th>Quantity</th>
                                <th>Unit Amount</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                decimal grandTotal = 0;
                                foreach (var detail in details)
                                {
                                    var itemTotal = detail.Quantity * detail.UnitAmount;
                                    grandTotal += itemTotal;
                            <tr>
                                <td>@detail.ItemId</td>
                                <td>@detail.Item?.ItemName</td>
                                <td>@detail.Quantity</td>
                                <td>@detail.UnitAmount.ToString("C")</td>
                                <td>@itemTotal.ToString("C")</td>
                            </tr>
                                }
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-dark">
                                <th colspan="4" class="text-end">Grand Total:</th>
                                <th>@grandTotal.ToString("C")</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
