@model Exer4MVCNetCore.Models.Order

@{
    ViewData["Title"] = "Create Order";
    var agents = ViewBag.Agents as List<Exer4MVCNetCore.Models.Agent> ?? new List<Exer4MVCNetCore.Models.Agent>();
    var items = ViewBag.Items as List<Exer4MVCNetCore.Models.Item> ?? new List<Exer4MVCNetCore.Models.Item>();
}

<div class="container mt-4">
    <h2>Create New Order</h2>
    <hr />

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var modelState in ViewData.ModelState.Values)
            {
                @foreach (var error in modelState.Errors)
                {
                    <p>@error.ErrorMessage</p>
                }
            }
        </div>
    }

    <form method="post" id="orderForm">
        @Html.AntiForgeryToken()

        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="AgentId" class="form-label">Select Agent</label>
                    <select asp-for="AgentId" class="form-select" required>
                        <option value="">-- Select an Agent --</option>
                        @foreach (var agent in agents)
                        {
                            <option value="@agent.AgentId">@agent.AgentName (@agent.AgentId)</option>
                        }
                    </select>
                    <span asp-validation-for="AgentId" class="text-danger"></span>
                </div>
            </div>
        </div>

        <h4 class="mt-4">Order Items</h4>
        <div class="table-responsive">
            <table class="table" id="orderItems">
                <thead class="table-dark">
                    <tr>
                        <th>Item</th>
                        <th>Quantity</th>
                        <th>Unit Amount</th>
                        <th>Total</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="itemRows">
                    <tr class="itemRow">
                        <td>
                            <select class="form-select itemSelect">
                                <option value="">-- Select Item --</option>
                                @foreach (var item in items)
                                {
                                    <option value="@item.ItemId" data-price="@item.Price">@item.ItemName (@item.ItemId)</option>
                                }
                            </select>
                        </td>
                        <td><input type="number" class="form-control quantity" value="1" min="1"></td>
                        <td><input type="number" class="form-control unitAmount" step="0.01" readonly></td>
                        <td><span class="itemTotal">0.00</span></td>
                        <td><button type="button" class="btn btn-sm btn-danger removeRow">Remove</button></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <button type="button" class="btn btn-secondary mb-3" id="addRow">Add Item</button>

        <div class="row mt-3">
            <div class="col-md-6">
                <h5>Total Order Amount: <span id="orderTotal">0.00</span></h5>
            </div>
        </div>

        <input type="hidden" id="itemIds" name="itemIds" value="">
        <input type="hidden" id="quantities" name="quantities" value="">
        <input type="hidden" id="unitAmounts" name="unitAmounts" value="">

        <div class="form-group mt-4">
            <button type="submit" class="btn btn-primary">Create Order</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

<script>
function updateRowTotal(row) {
    const quantity = parseFloat(row.querySelector('.quantity').value) || 0;
    const unitAmount = parseFloat(row.querySelector('.unitAmount').value) || 0;
    row.querySelector('.itemTotal').textContent = (quantity * unitAmount).toFixed(2);
    updateOrderTotal();
}

function updateOrderTotal() {
    let total = 0;
    document.querySelectorAll('.itemRow').forEach(row => {
        const quantity = parseFloat(row.querySelector('.quantity').value) || 0;
        const unitAmount = parseFloat(row.querySelector('.unitAmount').value) || 0;
        total += quantity * unitAmount;
    });
    document.getElementById('orderTotal').textContent = total.toFixed(2);
}

document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('addRow').addEventListener('click', function() {
        const newRow = document.querySelector('.itemRow').cloneNode(true);
        newRow.querySelector('.itemSelect').value = '';
        newRow.querySelector('.quantity').value = '1';
        newRow.querySelector('.unitAmount').value = '';
        newRow.querySelector('.itemTotal').textContent = '0.00';
        document.getElementById('itemRows').appendChild(newRow);
        attachRowListeners(newRow);
    });

    function attachRowListeners(row) {
        const itemSelect = row.querySelector('.itemSelect');
        const quantity = row.querySelector('.quantity');
        const unitAmount = row.querySelector('.unitAmount');
        const removeBtn = row.querySelector('.removeRow');

        itemSelect.addEventListener('change', function() {
            const selectedOption = this.options[this.selectedIndex];
            const price = selectedOption.getAttribute('data-price') || '0';
            unitAmount.value = price;
            updateRowTotal(row);
        });

        quantity.addEventListener('input', function() {
            updateRowTotal(row);
        });

        removeBtn.addEventListener('click', function() {
            if (document.querySelectorAll('.itemRow').length > 1) {
                row.remove();
                updateOrderTotal();
            } else {
                alert('Must have at least one item');
            }
        });
    }

    document.querySelectorAll('.itemRow').forEach(attachRowListeners);

    document.getElementById('orderForm').addEventListener('submit', function(e) {
        e.preventDefault();

        const itemIds = [];
        const quantities = [];
        const unitAmounts = [];

        document.querySelectorAll('.itemRow').forEach(row => {
            const itemId = row.querySelector('.itemSelect').value;
            if (itemId) {
                itemIds.push(itemId);
                quantities.push(row.querySelector('.quantity').value);
                unitAmounts.push(row.querySelector('.unitAmount').value);
            }
        });

        if (itemIds.length === 0) {
            alert('Please add at least one item');
            return;
        }

        document.getElementById('itemIds').value = itemIds.join(',');
        document.getElementById('quantities').value = quantities.join(',');
        document.getElementById('unitAmounts').value = unitAmounts.join(',');

        this.submit();
    });
});
</script>
