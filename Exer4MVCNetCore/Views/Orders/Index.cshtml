@model List<Exer4MVCNetCore.Models.OrderSummary>

@{
    ViewData["Title"] = "Orders";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2>Orders</h2>
        </div>
        <div class="col-md-6 text-end">
            <a href="@Url.Action("Create")" class="btn btn-success">Create New Order</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model != null && Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Order ID</th>
                        <th>Order Date</th>
                        <th>Agent ID</th>
                        <th>Total Amount</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>@order.OrderId</td>
                            <td>@order.OrderDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@order.AgentId</td>
                            <td>@order.TotalAmount.ToString("C")</td>
                            <td>
                                <a href="@Url.Action("Details", new { id = order.OrderId })" class="btn btn-sm btn-info">View</a>
                                <form method="post" action="@Url.Action("Print")" style="display: inline-block;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@order.OrderId" />
                                    <button type="submit" class="btn btn-sm btn-primary">Print</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No orders found. <a href="@Url.Action("Create")">Create one now</a></div>
    }
</div>
