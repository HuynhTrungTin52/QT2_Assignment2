@model List<Exer4MVCNetCore.Models.Item>

@{
    ViewData["Title"] = "Products";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2>Products</h2>
        </div>
        <div class="col-md-6 text-end">
            <a href="@Url.Action("Create")" class="btn btn-success">Add New Product</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model != null && Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Item ID</th>
                        <th>Item Name</th>
                        <th>Size</th>
                        <th>Price</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ItemId</td>
                            <td>@item.ItemName</td>
                            <td>@item.Size</td>
                            <td>@item.Price.ToString("C")</td>
                            <td>
                                <a href="@Url.Action("Edit", new { id = item.ItemId })" class="btn btn-sm btn-warning">Edit</a>
                                <form method="post" action="@Url.Action("Delete")" style="display: inline-block;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.ItemId" />
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No products found. <a href="@Url.Action("Create")">Add one now</a></div>
    }
</div>
