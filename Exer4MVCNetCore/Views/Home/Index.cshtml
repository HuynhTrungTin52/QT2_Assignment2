@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center py-5">
    <h1 class="display-4">Welcome to E-Commerce System</h1>
    <p class="lead">Manage your agents, products, and orders efficiently</p>
</div>

<div class="row">
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Products</h5>
                <p class="card-text">Manage your product catalog</p>
                <a href="@Url.Action("Index", "Products")" class="btn btn-primary">View Products</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Agents</h5>
                <p class="card-text">Manage your agents/dealers</p>
                <a href="@Url.Action("Index", "Agents")" class="btn btn-primary">View Agents</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Orders</h5>
                <p class="card-text">Create and manage orders</p>
                <a href="@Url.Action("Index", "Orders")" class="btn btn-primary">View Orders</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Reports</h5>
                <p class="card-text">View sales reports</p>
                <a href="@Url.Action("BestItems", "Reports")" class="btn btn-primary">View Reports</a>
            </div>
        </div>
    </div>
</div>
